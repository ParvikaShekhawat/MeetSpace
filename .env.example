DATABASE_URL="file:./dev.db"
JWT_SECRET="meetspace-dev-secret-change-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# LiveKit (optional — falls back to WebRTC if unset)
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL="wss://your-project.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"

# OpenAI (optional — falls back to heuristic analysis if unset)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email (optional — logs to console if unset)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MeetSpace <noreply@yourdomain.com>"
